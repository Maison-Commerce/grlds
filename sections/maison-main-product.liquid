{% schema %}
{
  "name": "Maison Main Product",
  "settings": [
    {
      "type": "header",
      "content": "Product Gallery Settings"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "label": "Gallery Layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid (2x2)"
        },
        {
          "value": "slider",
          "label": "Slider"
        }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show Limited Edition Badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "LIMITED EDITION"
    },
    {
      "type": "checkbox",
      "id": "auto_select_middle_size",
      "label": "Auto-select middle size on load",
      "info": "Automatically selects the middle size variant and syncs the gallery when the page opens.",
      "default": true
    },
    {
      "type": "select",
      "id": "smell_swatch_style",
      "label": "Smell option style",
      "info": "Image swatches use the Scent metaobject images; text shows the value as a pill.",
      "options": [
        {
          "value": "image",
          "label": "Image swatches"
        },
        {
          "value": "text",
          "label": "Text only"
        }
      ],
      "default": "image"
    },
    {
      "type": "header",
      "content": "Product Information"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating",
      "default": true
    },
    {
      "type": "richtext",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "<p>Rated <strong>4.8</strong> / 5 based on <u>3200+</u> reviews</p>"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_info",
      "label": "Show Shipping Info",
      "default": true
    },
    {
      "type": "richtext",
      "id": "shipping_text",
      "label": "Shipping Text",
      "default": "<p>Order before 14:00 → <u>Ships Today</u></p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Add to Cart Button Text",
      "default": "Add to Bag"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Free Refill / Founder Savings"
    },
    {
      "type": "text",
      "id": "free_refill_checkout_label",
      "label": "Checkout label",
      "info": "Shown before the checkout text as \"Label: text\" at checkout. The text comes from custom.free_refill_text_on_checkout.",
      "default": "Gift"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Ingredients"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "header",
          "content": "Specifications (burning time & weight)"
        },
        {
          "type": "checkbox",
          "id": "show_specs",
          "label": "Show specifications table",
          "default": true
        },
        {
          "type": "text",
          "id": "specs_caption",
          "label": "Caption",
          "default": "Burning time and weight of candle"
        },
        {
          "type": "text",
          "id": "spec_1_label",
          "label": "Row 1 — size",
          "default": "S"
        },
        {
          "type": "text",
          "id": "spec_1_burn",
          "label": "Row 1 — burn time",
          "default": "50h"
        },
        {
          "type": "text",
          "id": "spec_1_weight",
          "label": "Row 1 — weight",
          "default": "520g"
        },
        {
          "type": "text",
          "id": "spec_2_label",
          "label": "Row 2 — size",
          "default": "M"
        },
        {
          "type": "text",
          "id": "spec_2_burn",
          "label": "Row 2 — burn time",
          "default": "100h"
        },
        {
          "type": "text",
          "id": "spec_2_weight",
          "label": "Row 2 — weight",
          "default": "1.2kg"
        },
        {
          "type": "text",
          "id": "spec_3_label",
          "label": "Row 3 — size",
          "default": "L"
        },
        {
          "type": "text",
          "id": "spec_3_burn",
          "label": "Row 3 — burn time",
          "default": "340h"
        },
        {
          "type": "text",
          "id": "spec_3_weight",
          "label": "Row 3 — weight",
          "default": "3.2kg"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Signature Gift Wrap"
        }
      ]
    },
    {
      "type": "product-variants",
      "name": "Product related varaints",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Option name"
        }
      ]
    },
    {
      "type": "promo",
      "name": "Promotional Message",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "2 free samples of your choice with every order"
        }
      ]
    },
    {
      "type": "fragrance_info",
      "name": "Fragrance Info",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Adds an info icon next to the Fragrance option. Clicking it opens a popup with the three fragrances below. Notes are comma-separated and shown with • separators."
        },
        {
          "type": "header",
          "content": "Fragrance 1"
        },
        {
          "type": "text",
          "id": "part_1_title",
          "label": "Title",
          "default": "FIGUERES"
        },
        {
          "type": "text",
          "id": "part_1_list",
          "label": "Notes (comma-separated)",
          "default": "Green Fig, White Woods, Summer Shade"
        },
        {
          "type": "textarea",
          "id": "part_1_description",
          "label": "Description",
          "default": "The scent of an ancient fig tree standing quietly in the Mediterranean sun. Fresh green fig leaves blend with the creamy sweetness of ripe fruit, while soft woods and earthy notes create depth and warmth. Natural, elegant and calming, it captures the feeling of a slow summer afternoon beneath the shade of a fig tree."
        },
        {
          "type": "header",
          "content": "Fragrance 2"
        },
        {
          "type": "text",
          "id": "part_2_title",
          "label": "Title",
          "default": "AMBRE"
        },
        {
          "type": "text",
          "id": "part_2_list",
          "label": "Notes (comma-separated)",
          "default": "Warm Amber, Smoked Woods, Cashmere"
        },
        {
          "type": "textarea",
          "id": "part_2_description",
          "label": "Description",
          "default": "A warm and enveloping fragrance built around rich amber and precious woods. Subtle spices add depth, while soft musks create a smooth and refined finish. Sophisticated and comforting, it evokes the atmosphere of candlelight, aged wood and timeless interiors."
        },
        {
          "type": "header",
          "content": "Fragrance 3"
        },
        {
          "type": "text",
          "id": "part_3_title",
          "label": "Title",
          "default": "ZAGARA"
        },
        {
          "type": "text",
          "id": "part_3_list",
          "label": "Notes (comma-separated)",
          "default": "Orange Blossom, Citrus Grove, Morning Light"
        },
        {
          "type": "textarea",
          "id": "part_3_description",
          "label": "Description",
          "default": "Inspired by the orange groves of the Mediterranean coast in full bloom. Delicate orange blossom is layered with fresh citrus notes and soft floral accords, creating a fragrance that feels bright, radiant and uplifting. Elegant yet effortless, it captures the beauty of a warm spring morning filled with sunlight and blooming flowers."
        }
      ]
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout.label",
          "info": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout.info"
        },
        {
          "type": "checkbox",
          "id": "show_gift_card_recipient",
          "default": true,
          "label": "t:sections.main-product.blocks.buy_buttons.settings.show_gift_card_recipient.label",
          "info": "t:sections.main-product.blocks.buy_buttons.settings.show_gift_card_recipient.info"
        },
        {
          "type": "checkbox",
          "id": "skip_cart",
          "label": "t:settings_schema.lumintheme.buy_buttons.skip_cart.label",
          "default": false,
          "info": "t:settings_schema.lumintheme.buy_buttons.skip_cart.info"
        },
        {
          "type": "header",
          "content": "Button Settings"
        },
        {
          "type": "range",
          "id": "button_padding_top",
          "label": "Button Padding Top",
          "default": 20,
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px"
          },  
          {
          "type": "range",
          "id": "button_padding_bottom",
          "label": "Button Padding Bottom",
          "default": 20,
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px"
        },
        {
          "type": "checkbox",
          "id": "button_custom_style",
          "label": "Use custom button size",
          "default": false
        },
        {
          "type": "range",
          "id": "button_font_size",
          "label": "Button font size",
          "default": 20,
          "min": 10,
          "max": 50,
          "step": 1,
          "unit": "px",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "range",
          "id": "button_height",
          "label": "Button height",
          "default": 45,
          "min": 30,
          "max": 100,
          "step": 1,
          "unit": "px",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        
        {
          "type": "color",
          "id": "lm_main_button",
          "label": "Button Background",
          "default": "#000",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "color_background",
          "id": "lm_main_button_gr",
          "label": "Button Gradiant",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "color",
          "id": "lm_main_text",
          "label": "Cart Button Text",
          "default": "#fff",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "color",
          "id": "lm_main_text_hover",
          "label": "Cart Button background Hover",
          "default": "#0B57D0",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "color",
          "id": "lm_main_button_hover",
          "label": "Cart Button text Hover",
          "default": "#ffffff",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "color_background",
          "id": "lm_main_button_gr_hover",
          "label": "Cart Button Gradiant Hover",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "range",
          "id": "lm_main_button_border_width",
          "label": "Button Border Width",
          "default": 0,
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "px",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "color",
          "id": "lm_main_button_border_color",
          "label": "Button Border Color",
          "default": "#000",
          "visible_if": "{{block.settings.button_custom_style}}"
        },
        {
          "type": "paragraph",
          "content": "t:settings_schema.lumintheme.buy_buttons.paragraph.content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Maison Main Product"
    }
  ]
}
{% endschema %}

<product-info
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  data-product-json="{{ product | json | escape }}"
  data-variant-metafields="{{ product.variants | map: 'id' | json }}"
>
  {%- comment -%} Create variant metafields mapping {%- endcomment -%}
  <script type="application/json" id="variant-metafields-{{ section.id }}">
    {
      {%- for variant in product.variants -%}
        "{{ variant.id }}": {
          "size_additional_description": {{ variant.metafields.custom.size_additional_description | json | default: 'null' }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    }
  </script>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    @media screen and (min-width: 991px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top_desktop }}px;
        padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      }
    }
  {%- endstyle -%}

  <div class="maison_commerce_maison_main_product section-{{ section.id }}-padding">
    <div class="maison_commerce_maison_main_product__container">
      <div class="maison_commerce_maison_main_product__wrapper">
        <!-- Product Gallery -->
        {%- liquid
          assign has_size_option = false
          assign size_values = ''
          assign size_option_position = 0
          for option in product.options_with_values
            assign _opt_name = option.name | downcase
            if _opt_name == 'size'
              assign has_size_option = true
              assign size_values = option.values | join: ','
              assign size_option_position = forloop.index
            endif
          endfor
        -%}
        <div class="maison_commerce_maison_main_product__gallery" style="--media-radius: 0">
          {% if section.settings.gallery_layout == 'grid' %}
            <!-- Desktop Grid Layout -->
            <div class="maison_commerce_maison_main_product__gallery-grid" data-gallery-grid>
              {% for media in product.media %}
                {%- assign media_sizes = '' -%}
                {%- if has_size_option -%}
                  {%- capture media_sizes -%}{%- render 'media-size-match', media: media, size_values: size_values -%}{%- endcapture -%}
                  {%- assign media_sizes = media_sizes | strip -%}
                {%- endif -%}
                <div
                  class="maison_commerce_maison_main_product__gallery-item{% if forloop.index > 4 %} is-collapsed-hidden{% endif %}"
                  data-gallery-item
                  data-media-sizes="{{ media_sizes }}"
                >
                  {% if section.settings.show_badge %}
                    <div class="maison_commerce_maison_main_product__badge"{% unless forloop.first %} style="display: none;"{% endunless %}>
                      {{ section.settings.badge_text | default: 'LIMITED EDITION' }}
                    </div>
                  {% endif %}
                  {% if media.media_type == 'video' %}
                    {%- assign sorted_video_sources = media.sources | sort: 'width' | reverse -%}
                    <video
                      class="maison_commerce_maison_main_product__gallery-video"
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      poster="{{ media.preview_image | image_url: width: 1100 }}"
                      data-media-id="{{ media.id }}"
                    >
                      {%- for source in sorted_video_sources -%}
                        <source src="{{ source.url }}" type="{{ source.mime_type }}">
                      {%- endfor -%}
                    </video>
                  {% else %}
                    {% render 'product-media', media: media %}
                  {% endif %}
                </div>
              {% endfor %}
            </div>

            {% if product.media.size > 4 %}
              <button
                type="button"
                class="maison_commerce_maison_main_product__view-all"
                data-gallery-toggle
                aria-expanded="false"
              >
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0.5" y="0.5" width="5" height="5" stroke="currentColor"/>
                  <rect x="8.5" y="0.5" width="5" height="5" stroke="currentColor"/>
                  <rect x="0.5" y="8.5" width="5" height="5" stroke="currentColor"/>
                  <rect x="8.5" y="8.5" width="5" height="5" stroke="currentColor"/>
                </svg>
                <span
                  data-gallery-toggle-label
                  data-label-more="View all photos"
                  data-label-less="Show less"
                >View all photos ({{ product.media.size }})</span>
              </button>
            {% endif %}
          {% endif %}

          <!-- Mobile Slider Layout -->
          <div class="swiper maison_commerce_maison_main_product__gallery-slider">
            <div class="swiper-wrapper">
              {% for media in product.media %}
                {%- assign media_sizes = '' -%}
                {%- if has_size_option -%}
                  {%- capture media_sizes -%}{%- render 'media-size-match', media: media, size_values: size_values -%}{%- endcapture -%}
                  {%- assign media_sizes = media_sizes | strip -%}
                {%- endif -%}
                <div class="swiper-slide maison_commerce_maison_main_product__gallery-slide" data-media-id="{{ media.id }}" data-media-sizes="{{ media_sizes }}">
                  {% if section.settings.show_badge %}
                    <div class="maison_commerce_maison_main_product__badge"{% unless forloop.first %} style="display: none;"{% endunless %}>
                      {{ section.settings.badge_text | default: 'LIMITED EDITION' }}
                    </div>
                  {% endif %}
                  {% if media.media_type == 'video' %}
                    {%- assign sorted_video_sources = media.sources | sort: 'width' | reverse -%}
                    <video
                      class="maison_commerce_maison_main_product__gallery-video"
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      poster="{{ media.preview_image | image_url: width: 1100 }}"
                      data-media-id="{{ media.id }}"
                    >
                      {%- for source in sorted_video_sources -%}
                        <source src="{{ source.url }}" type="{{ source.mime_type }}">
                      {%- endfor -%}
                    </video>
                  {% else %}
                    {% render 'product-media', media: media %}
                  {% endif %}
                </div>
              {% endfor %}
            </div>
            <!-- Slider Pagination -->
            <div class="swiper-pagination maison_commerce_maison_main_product__gallery-pagination"></div>
          </div>
        </div>

        <!-- Product Information -->
        <div class="maison_commerce_maison_main_product__info">
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          <!-- Product Name Section -->
          <div class="maison_commerce_maison_main_product__name-section">
            <div class="maison_commerce_maison_main_product__name-section-inner">
              <!-- Rating -->
              {% if section.settings.show_rating %}
                <div class="maison_commerce_maison_main_product__rating">
                  <div class="maison_commerce_maison_main_product__stars">
                    {% for i in (1..5) %}
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 0L9.79811 5.52786H15.6085L10.9052 8.94427L12.7033 14.4721L8 11.0557L3.29667 14.4721L5.09478 8.94427L0.391548 5.52786H6.20189L8 0Z" fill="#1A1A1A"/>
                      </svg>
                    {% endfor %}
                  </div>
                  <span class="maison_commerce_maison_main_product__rating-text">
                    {{ section.settings.rating_text | default: '4.8 / 5 (<u>3,200 reviews</u>)' }}
                  </span>
                </div>
              {% endif %}

              <!-- Product Title -->
              <h1 class="maison_commerce_maison_main_product__title">
                {{ product.title }}
              </h1>

              <!-- Product Description -->
              {% if product.description != blank %}
                <div class="maison_commerce_maison_main_product__description">
                  {{ product.description }}
                </div>
              {% endif %}
            </div>

            <!-- Price -->
            {%- liquid
              assign free_refill_badge = product.metafields.custom.free_refill_badge
              assign free_refill_refill_text = product.metafields.custom.free_refill_text_on_checkout

              assign show_founder_badge = false
              if free_refill_badge != blank
                assign show_founder_badge = true
              endif

              assign show_refill_badge = false
              if free_refill_refill_text != blank
                assign show_refill_badge = true
              endif

              assign founder_text = ''
              if show_founder_badge
                assign fr_variant = product.selected_or_first_available_variant
                assign fr_compare = fr_variant.compare_at_price
                assign fr_percent = 0
                if fr_compare > 0
                  assign fr_diff = fr_compare | minus: fr_variant.price
                  assign fr_percent = fr_diff | times: 100.0 | divided_by: fr_compare | round
                  if fr_percent < 0
                    assign fr_percent = 0
                  endif
                endif
                assign fr_percent_str = fr_percent | append: '%'
                assign founder_text = free_refill_badge | replace: '[percent]', fr_percent_str
              endif
            -%}
            <div class="maison_commerce_maison_main_product__price-row{% if show_founder_badge %} has-founder-badges{% endif %}">
              <div class="maison_commerce_maison_main_product__price">
                {%- render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' -%}
              </div>
              {%- if show_founder_badge or show_refill_badge -%}
                <div
                  class="maison_commerce_maison_main_product__founder-badges"
                  id="founder-badges-{{ section.id }}"
                >
                  {%- if show_founder_badge -%}
                    <span class="maison_commerce_maison_main_product__badge-founder" data-founder-badge>{{ founder_text }}</span>
                  {%- endif -%}
                  {%- if show_refill_badge -%}
                    <span class="maison_commerce_maison_main_product__badge-refill">{{ free_refill_refill_text }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>

          <!-- Variant Picker: Size -->
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              {% if option.name == 'Size' or option.name == 'SIZE' %}
                {% assign option_index = forloop.index %}
                <div class="maison_commerce_maison_main_product__variant maison_commerce_maison_main_product__variant--size">
                  <div class="maison_commerce_maison_main_product__variant-header-wrapper">
                    <div class="maison_commerce_maison_main_product__variant-header">
                        <span class="maison_commerce_maison_main_product__variant-label">SIZE:</span>
                        <span class="maison_commerce_maison_main_product__variant-value" id="selected-size-{{ section.id }}">
                        {{ option.selected_value }}
                        </span>
                    </div>
                    {% if option.name == 'Size' %}
                        <div class="maison_commerce_maison_main_product__room-info" id="room-info-{{ section.id }}">
                          {% assign selected_variant = product.selected_or_first_available_variant %}
                          {% if selected_variant.metafields.custom.size_additional_description != blank %}
                            {{ selected_variant.metafields.custom.size_additional_description }}
                          {% endif %}
                        </div>
                    {% endif %}
                  </div>
                  <div class="maison_commerce_maison_main_product__variant-thumbnails">
                    {% for value in option.values %}
                      <button
                        type="button"
                        class="maison_commerce_maison_main_product__variant-thumbnail{% if value == option.selected_value %} active{% endif %}"
                        data-value="{{ value }}"
                        data-option-position="{{ option_index }}"
                        aria-label="{{ value }}"
                      >
                        {% assign variant = product.variants | where: 'option1', value | first %}
                        {% if variant.featured_image %}
                          {{
                            variant.featured_image
                            | image_url: width: 128
                            | image_tag: loading: 'lazy', alt: value
                          }}
                        {% else %}
                          {{
                            product.featured_image
                            | image_url: width: 128
                            | image_tag: loading: 'lazy', alt: value
                          }}
                        {% endif %}
                      </button>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            {% endfor %}

            <!-- Variant Picker: Smell/Stone Type -->
            {%- assign fragrance_info_block = section.blocks | where: 'type', 'fragrance_info' | first -%}
            {% for option in product.options_with_values %}
              {% if option.name != 'Size' %}
                {% assign option_index = forloop.index %}
                <div class="maison_commerce_maison_main_product__variant maison_commerce_maison_main_product__variant--smell">
                  <div class="maison_commerce_maison_main_product__variant-header">
                    <span class="maison_commerce_maison_main_product__variant-label">{{ option.name | upcase }}:</span>
                    <span class="maison_commerce_maison_main_product__variant-value" id="selected-smell-{{ section.id }}">
                      {{ option.selected_value }}
                    </span>
                    {%- if fragrance_info_block -%}
                      <button
                        type="button"
                        class="maison_commerce_maison_main_product__fragrance-info-btn"
                        data-fragrance-info-open
                        aria-label="Fragrance details"
                        aria-haspopup="dialog"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 50 50" fill="currentColor">
                          <path d="M 25 2 C 12.309295 2 2 12.309295 2 25 C 2 37.690705 12.309295 48 25 48 C 37.690705 48 48 37.690705 48 25 C 48 12.309295 37.690705 2 25 2 z M 25 4 C 36.609824 4 46 13.390176 46 25 C 46 36.609824 36.609824 46 25 46 C 13.390176 46 4 36.609824 4 25 4 z M 25 11 A 3 3 0 0 0 22 14 A 3 3 0 0 0 25 17 A 3 3 0 0 0 28 14 A 3 3 0 0 0 25 11 z M 21 21 L 21 23 L 22 23 L 23 23 L 23 36 L 22 36 L 21 36 L 21 38 L 22 38 L 23 38 L 27 38 L 28 38 L 29 38 L 29 36 L 28 36 L 27 36 L 27 21 L 26 21 L 22 21 L 21 21 z"></path>
                        </svg>
                      </button>
                    {%- endif -%}
                  </div>
                  <div class="maison_commerce_maison_main_product__variant-options">
                    {% for value in option.values %}
                      {%- assign scent_handle = value | handleize -%}
                      {%- assign scent = metaobjects.scent[scent_handle] -%}
                      {%- assign show_scent_img = false -%}
                      {%- if section.settings.smell_swatch_style == 'image' and scent.image != blank -%}
                        {%- assign show_scent_img = true -%}
                      {%- endif -%}
                      <button
                        type="button"
                        class="maison_commerce_maison_main_product__variant-option{% if show_scent_img %} maison_commerce_maison_main_product__variant-option--has-img{% endif %}{% if value == option.selected_value %} active{% endif %}"
                        data-value="{{ value }}"
                        data-option-position="{{ option_index }}"
                        aria-label="{{ value }}"
                      >
                        {% if show_scent_img %}
                          <span class="maison_commerce_maison_main_product__variant-option-img">
                            {{
                              scent.image
                              | image_url: width: 160
                              | image_tag: loading: 'lazy', alt: value
                            }}
                          </span>
                        {% else %}
                          {{ value | upcase }}
                        {% endif %}
                      </button>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            {% endfor %}

            {% for block in section.blocks %}
              {% if block.type == 'product-variants' %}
                {% if product.metafields.custom.related_products != blank %}
                  {% render 'product-custom-variant-picker',
                    product: product,
                    title: block.settings.title
                  %}
                {% endif %}
              {% endif %}
            {% endfor %}

            <!-- Hidden Variant Picker Form -->
            <div class="maison_commerce_maison_main_product__variant-picker-hidden" style="display: none;">
              {%- comment -%} Create variant-selects element directly {%- endcomment -%}
              <variant-selects
                id="variant-selects-{{ section.id }}"
                data-section="{{ section.id }}"
              >
                {%- for option in product.options_with_values -%}
                  {% assign option_index = forloop.index %}
                  <fieldset class="js product-form__input product-form__input--pill">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign option_disabled = true
                        if value.available
                          assign option_disabled = false
                        endif
                      -%}
                      <input
                        type="radio"
                        id="Option-{{ section.id }}-{{ option_index }}-{{ forloop.index0 }}"
                        name="options[{{ option_index }}]"
                        value="{{ value }}"
                        form="{{ product_form_id }}"
                        {% if value == option.selected_value %}checked{% endif %}
                        {% if option_disabled %}disabled{% endif %}
                      >
                      <label for="Option-{{ section.id }}-{{ option_index }}-{{ forloop.index0 }}">
                        {{ value }}
                      </label>
                    {%- endfor -%}
                  </fieldset>
                {%- endfor -%}
                <script type="application/json" data-selected-variant>
                  {{ product.selected_or_first_available_variant | json }}
                </script>
              </variant-selects>
            </div>
          {% endunless %}

          <!-- Action Section (Shipping, Button, Payment, Benefits) -->
          <div class="maison_commerce_maison_main_product__action-section">
            <!-- Shipping Info -->
            {% if section.settings.show_shipping_info %}
              <div class="maison_commerce_maison_main_product__shipping">
                {{ section.settings.shipping_text | default: 'Order before 14:00 → <u>Ships Today</u>' }}
              </div>
            {% endif %}

            <!-- Add to Cart Form -->
            {% assign buy_buttons_blocks = section.blocks | where: 'type', 'buy_buttons' %}
            {% for block in buy_buttons_blocks %}
              {% if block.settings.button_custom_style %}
                <style>
                  .lumin-submit {
                    font-size: {{ block.settings.button_font_size }}px;
                    height: {{ block.settings.button_height }}px;
                    background-color: {{block.settings.lm_main_button}};
                    background: {{block.settings.lm_main_button_gr}};
                    color: {{block.settings.lm_main_text}};
                    border: {{block.settings.lm_main_button_border_width}}px solid {{block.settings.lm_main_button_border_color}};
                  }
                  .lumin-submit:hover {
                    background-color: {{block.settings.lm_main_text_hover}} !important;
                    background: {{block.settings.lm_main_button_gr_hover}} !important;
                    color: {{block.settings.lm_main_button_hover}} !important;
                  }
                  .lumin-submit::after {
                    box-shadow: 0 0 0 0
                    rgba(var(--lm-button-box), var(--border-opacity)),
                    0 0 0 var(--buttons-border-width) rgb(255 204 4 / 0%) !important;
                  }
                  .product__info-container .product-form {
                    margin: {{block.settings.button_padding_top}}px 0 {{block.settings.button_padding_bottom}}px 0;
                  }
                </style>
                {% endif %}
                {%- render 'buy-buttons',
                  block: block,
                  product: product,
                  product_form_id: product_form_id,
                  section_id: section.id,
                  show_pickup_availability: true
                -%}
            {% endfor %}

            <!-- Free refill checkout note (hidden in cart, visible at checkout) -->
            {%- assign free_refill_checkout = product.metafields.custom.free_refill_text_on_checkout -%}
            {%- if free_refill_checkout != blank -%}
              {%- assign free_refill_label = section.settings.free_refill_checkout_label | default: 'Gift' -%}
              <input
                type="hidden"
                name="properties[{{ free_refill_label | escape }}]"
                value="{{ free_refill_checkout | escape }}"
                form="{{ product_form_id }}"
              >
            {%- endif -%}

            <!-- Payment Icons -->
            {% if section.settings.show_payment_icons %}
              <div class="maison_commerce_maison_main_product__payment-icons">
                {%- for type in shop.enabled_payment_types -%}
                  <div class="maison_commerce_maison_footer__payment-icon">{{ type | payment_type_svg_tag }}</div>
                {%- endfor -%}
              </div>
            {% endif %}

            <!-- Benefits -->
            {% assign benefit_blocks = section.blocks | where: 'type', 'benefit' %}
            {% if benefit_blocks.size > 0 %}
              <div class="maison_commerce_maison_main_product__benefits">
              {% for block in benefit_blocks %}
                {% if forloop.index > 1 %}
                  <div class="maison_commerce_maison_main_product__benefit-divider"></div>
                {% endif %}
                <div class="maison_commerce_maison_main_product__benefit" {{ block.shopify_attributes }}>
                  {% if block.settings.icon != blank %}
                    <div class="maison_commerce_maison_main_product__benefit-icon">
                      {{
                        block.settings.icon
                        | image_url: width: 32
                        | image_tag: loading: 'lazy', alt: block.settings.text, class: 'maison_commerce_maison_main_product__benefit-icon-img'
                      }}
                    </div>
                  {% endif %}
                  <span>{{ block.settings.text }}</span>
                </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>

          <!-- Accordions -->
          {% if section.blocks.size > 0 %}
            <div class="maison_commerce_maison_main_product__accordions">
              {% for block in section.blocks %}
                {% if block.type == 'accordion' %}
                  <div class="maison_commerce_maison_main_product__accordion" {{ block.shopify_attributes }}>
                    <details>
                      <summary class="maison_commerce_maison_main_product__accordion-header">
                        <span>{{ block.settings.title }}</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                        <path d="M6.875 0V13.75" stroke="currentColor"/>
                        <path d="M0 6.875H13.75" stroke="currentColor"/>
                        </svg>
                      </summary>
                      <div class="maison_commerce_maison_main_product__accordion-content">
                        {{ block.settings.content }}
                        {% if block.settings.show_specs %}
                          <div class="maison_commerce_maison_main_product__accordion-specs">
                            <div class="maison_commerce_maison_main_product__specs-table">
                              <div class="maison_commerce_maison_main_product__specs-row maison_commerce_maison_main_product__specs-row--head">
                                <span class="maison_commerce_maison_main_product__specs-cell"></span>
                                <span class="maison_commerce_maison_main_product__specs-cell">
                                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 2c1.5 3 5 5.5 5 10a5 5 0 0 1-10 0c0-2 1-3.5 2-4.5C9.5 9 10 11 11 11.5 11 9 12 4.5 12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                  </svg>
                                  <span>Burn time</span>
                                </span>
                                <span class="maison_commerce_maison_main_product__specs-cell">
                                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M9 3h6l1 3H8l1-3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                    <path d="M5 21 7.5 6h9L19 21H5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                  </svg>
                                  <span>Weight</span>
                                </span>
                              </div>
                              {% for i in (1..3) %}
                                {% capture label_key %}spec_{{ i }}_label{% endcapture %}
                                {% capture burn_key %}spec_{{ i }}_burn{% endcapture %}
                                {% capture weight_key %}spec_{{ i }}_weight{% endcapture %}
                                {% assign spec_label = block.settings[label_key] %}
                                {% assign spec_burn = block.settings[burn_key] %}
                                {% assign spec_weight = block.settings[weight_key] %}
                                {% if spec_label != blank or spec_burn != blank or spec_weight != blank %}
                                  <div class="maison_commerce_maison_main_product__specs-row">
                                    <span class="maison_commerce_maison_main_product__specs-cell maison_commerce_maison_main_product__specs-size">{{ spec_label }}</span>
                                    <span class="maison_commerce_maison_main_product__specs-cell">{{ spec_burn }}</span>
                                    <span class="maison_commerce_maison_main_product__specs-cell">{{ spec_weight }}</span>
                                  </div>
                                {% endif %}
                              {% endfor %}
                            </div>
                            {% if block.settings.specs_caption != blank %}
                              <p class="maison_commerce_maison_main_product__specs-caption">{{ block.settings.specs_caption }}</p>
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if block.settings.image != blank %}
                          <div class="maison_commerce_maison_main_product__accordion-image">
                            {{
                              block.settings.image
                              | image_url: width: 1000
                              | image_tag:
                                loading: 'lazy',
                                class: 'maison_commerce_maison_main_product__accordion-image-img',
                                alt: block.settings.image.alt
                            }}
                          </div>
                        {% endif %}
                      </div>
                    </details>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

          <!-- Promotional Message -->
          {% assign promo_blocks = section.blocks | where: 'type', 'promo' %}
          {% for block in promo_blocks %}
            {% if block.settings.text != blank %}
              <div class="maison_commerce_maison_main_product__promo" {{ block.shopify_attributes }}>
                {% if block.settings.icon != blank %}
                  <div class="maison_commerce_maison_main_product__promo-icon">
                    {{
                      block.settings.icon
                      | image_url: width: 28
                      | image_tag: loading: 'lazy', alt: block.settings.text, class: 'maison_commerce_maison_main_product__promo-icon-img'
                    }}
                  </div>
                {% endif %}
                <span>{{ block.settings.text }}</span>
              </div>
            {% endif %}
          {% endfor %}

          <!-- Size Chart Image -->
          {% if product.metafields.custom.size_chart != blank %}
            <div class="maison_commerce_maison_main_product__size-chart">
              {{
                product.metafields.custom.size_chart
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  class: 'maison_commerce_maison_main_product__size-chart-img',
                  alt: 'Size Chart'
              }}
            </div>
          {% endif %}

          <!-- Fragrance Info Popup -->
          {% if fragrance_info_block %}
            <div class="maison_commerce_maison_main_product__fragrance-modal" data-fragrance-modal aria-hidden="true">
              <div class="maison_commerce_maison_main_product__fragrance-modal-overlay" data-fragrance-info-close></div>
              <div class="maison_commerce_maison_main_product__fragrance-modal-dialog" role="dialog" aria-modal="true" aria-label="Fragrance details">
                <button
                  type="button"
                  class="maison_commerce_maison_main_product__fragrance-modal-close"
                  data-fragrance-info-close
                  aria-label="Close"
                >
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L17 17M17 1L1 17" stroke="currentColor"/>
                  </svg>
                </button>
                <div class="maison_commerce_maison_main_product__fragrance-modal-content">
                  {% for i in (1..3) %}
                    {% capture title_key %}part_{{ i }}_title{% endcapture %}
                    {% capture desc_key %}part_{{ i }}_description{% endcapture %}
                    {% capture list_key %}part_{{ i }}_list{% endcapture %}
                    {% assign part_title = fragrance_info_block.settings[title_key] %}
                    {% assign part_desc = fragrance_info_block.settings[desc_key] %}
                    {% assign part_list = fragrance_info_block.settings[list_key] %}
                    {% if part_title != blank or part_desc != blank or part_list != blank %}
                      <div class="maison_commerce_maison_main_product__fragrance-part">
                        {% if part_title != blank %}
                          <h3 class="maison_commerce_maison_main_product__fragrance-part-title">{{ part_title }}</h3>
                        {% endif %}
                        {% if part_desc != blank %}
                          <p class="maison_commerce_maison_main_product__fragrance-part-desc">{{ part_desc }}</p>
                        {% endif %}
                        {% if part_list != blank %}
                          <div class="maison_commerce_maison_main_product__fragrance-part-list">
                            {% assign part_items = part_list | split: ',' %}
                            {% for item in part_items %}
                              <span class="maison_commerce_maison_main_product__fragrance-part-list-item">{{ item | strip }}</span>
                              {% unless forloop.last %}<span class="maison_commerce_maison_main_product__fragrance-part-list-sep">•</span>{% endunless %}
                            {% endfor %}
                          </div>
                        {% endif %}
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</product-info>

<style>
  .maison_commerce_maison_main_product {
    background-color: #ffffff;
  }

  .maison_commerce_maison_main_product__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__container {
      padding: 0 18px;
    }
  }

  .maison_commerce_maison_main_product__wrapper {
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__wrapper {
      flex-direction: column;
      gap: 12px;
    }
  }

  /* Gallery */
  .maison_commerce_maison_main_product__gallery {
    flex: 1;
    position: sticky;
    top: 0;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__gallery {
      flex: 1;
      width: 100%;
      position: relative;
    }
  }

  .maison_commerce_maison_main_product__gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__gallery-grid {
      display: none;
    }
  }

  .maison_commerce_maison_main_product__gallery-item {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 0;
  }

  .maison_commerce_maison_main_product__gallery-item img,
  .maison_commerce_maison_main_product__gallery-item video{
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__gallery-item {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
    }
  }

  .maison_commerce_maison_main_product__gallery-slider {
    display: none!important;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__gallery-slider {
      display: block!important;
      width: 100%;
      overflow: visible!important;
    }

    .maison_commerce_maison_main_product{
      overflow: hidden!important;
    }
  }

  .maison_commerce_maison_main_product__gallery-slide {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
  }
  
  .maison_commerce_maison_main_product__gallery-slide img,
  .maison_commerce_maison_main_product__gallery-slide video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .maison_commerce_maison_main_product__badge {
    position: absolute;
    top: 12px;
    left: 13px;
    background: white;
    padding: 2px 8px;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(26, 26, 26, 0.75);
    z-index: 1;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__gallery-grid {
      display: none;
    }
  }

  /* Swiper Pagination Styles */
  .maison_commerce_maison_main_product__gallery-pagination {
    display: none;
    position: relative;
    margin-top: 8px;
    text-align: center;
    position: relative!important;
    top: auto!important;
    left: auto!important;
    right: auto!important;
    bottom: auto!important;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__gallery-pagination {
      display: block;
    }
  }

  .maison_commerce_maison_main_product__gallery-pagination .swiper-pagination-bullet {
    width: 24px;
    height: 4px;
    border-radius: 90px;
    background-color: #e6e6e6;
    opacity: 1;
    margin: 0 3.55px;
    transition: all 0.3s ease;
  }

  .maison-add-to-cart-button-dot{
    color: var(--Color-Brand-1-1200, #434343);
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 24px;
    letter-spacing: 0.32px;
  }

  .maison_commerce_maison_main_product__gallery-pagination .swiper-pagination-bullet-active {
    width: 32px;
    background-color: #2d2d2d;
  }

  /* View all photos button */
  .maison_commerce_maison_main_product__view-all {
    margin-top: 20px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 22px;
    background: #fff;
    border: none;
    outline: 1px solid rgba(0, 0, 0, 0.08);
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #1a1a1a;
    cursor: pointer;
    transition: outline-color 0.3s ease, background-color 0.3s ease;
  }

  .maison_commerce_maison_main_product__view-all:hover {
    outline-color: #1a1a1a;
    background: #fafafa;
  }

  .maison_commerce_maison_main_product__view-all svg {
    flex-shrink: 0;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__view-all {
      display: none;
    }
  }

  /* Grid items hidden either because they don't match the selected Size,
     or because they're collapsed behind the "View all photos" button */
  .maison_commerce_maison_main_product__gallery-item.is-size-hidden,
  .maison_commerce_maison_main_product__gallery-item.is-collapsed-hidden {
    display: none;
  }

  /* Product Info */
  .maison_commerce_maison_main_product__info {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__info {
      max-width: 100%;
    }
  }

  /* Product Name Section (Rating, Title, Description, Price) */
  .maison_commerce_maison_main_product__name-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__name-section {
      gap: 4px;
    }
  }

  .maison_commerce_maison_main_product__name-section-inner {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* Rating */
  .maison_commerce_maison_main_product__rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .maison_commerce_maison_main_product__stars {
    display: flex;
    gap: 0;
  }

  .maison_commerce_maison_main_product__rating-text {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: #1a1a1a;
  }

  /* Title */
  .maison_commerce_maison_main_product__title {
    font-family: 'Dangmen', sans-serif;
    font-size: 32px;
    font-weight: 400;
    line-height: 1.3;
    color: #1a1a1a;
    text-transform: uppercase;
    margin: 0;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__title {
      font-size: 24px;
      line-height: 1.4;
    }
  }

  /* Description */
  .maison_commerce_maison_main_product__description {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(26, 26, 26, 0.75);
  }

  .maison_commerce_maison_main_product__description p {
    margin: 0;
  }

  /* Price */
  .maison_commerce_maison_main_product__price {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .maison_commerce_maison_main_product__price .price{
    display: flex;
    align-items: center;
  }

  .maison_commerce_maison_main_product__price .price-item--sale{
    color: var(--Text-Primary, #1A1A1A);
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 24px;
    letter-spacing: 0.32px;
    margin-right: 4px!important;
  }

  .maison_commerce_maison_main_product__price .price-item--strikethrough{
    color: var(--Color-Brand-1-900, #6C6C6C);
    font-size: 16px!important;
    font-style: normal;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: 0.32px;
    text-decoration-line: line-through;
    margin-right: 8px!important;
  }

  .maison_commerce_maison_main_product__price .price__badge-sale{
     font-size: 12px;
     color: var(--Text-Secondary, rgba(26, 26, 26, 0.75));
  }

  .maison_commerce_maison_main_product__price .price__badge-sold-out{
    display: none!important;
  }

  .maison_commerce_maison_main_product__price .price-item--regular{
    color: var(--Text-Primary, #1A1A1A);
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 24px;
    letter-spacing: 0.32px;
    margin-right: 4px!important;
  }

  /* Price row + Founder Savings / Free Refill badges */
  .maison_commerce_maison_main_product__price-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* When the founder badges replace the default sale badge, hide the default one */
  .maison_commerce_maison_main_product__price-row.has-founder-badges .price__badge-sale {
    display: none !important;
  }

  .maison_commerce_maison_main_product__founder-badges {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .maison_commerce_maison_main_product__badge-founder,
  .maison_commerce_maison_main_product__badge-refill {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.9px;
    white-space: nowrap;
  }

  .maison_commerce_maison_main_product__badge-founder {
    background: #1c1c1c;
    color: #ffffff;
  }

  .maison_commerce_maison_main_product__badge-refill {
    background: #f2f2f2;
    color: rgba(26, 26, 26, 0.75);
  }

  @media (max-width: 990px) {
    /* Mobile: price on the first line, badges wrap to the line below */
    .maison_commerce_maison_main_product__price-row .maison_commerce_maison_main_product__founder-badges {
      flex-basis: 100%;
    }
  }

  /* Spacing between main sections */
  .maison_commerce_maison_main_product__name-section {
    margin-bottom: 24px;
  }

  .maison_commerce_maison_main_product__variant--size {
    margin-bottom: 24px;
  }

  .maison_commerce_maison_main_product__variant--smell {
    margin-bottom: 24px;
  }

  .maison_commerce_maison_main_product__action-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 40px;
  }

  .maison_commerce_maison_main_product__accordions {
    margin-bottom: 12px;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__name-section {
      margin-bottom: 20px;
    }

    .maison_commerce_maison_main_product__variant--size {
      margin-bottom: 20px;
    }

    .maison_commerce_maison_main_product__variant--smell {
      margin-bottom: 20px;
    }

    .maison_commerce_maison_main_product__action-section {
      margin-bottom: 20px;
      gap: 12px;
    }

    .maison_commerce_maison_main_product__accordions {
      margin-bottom: 18px;
    }

    .maison_commerce_maison_main_product__promo{
      margin-bottom: 8px;
    }
  }

  /* Variant Picker */
  .maison_commerce_maison_main_product__variant {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .maison_commerce_maison_main_product__variant-header-wrapper{
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .maison_commerce_maison_main_product__variant-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .maison_commerce_maison_main_product__variant-label {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.5;
    color: rgba(26, 26, 26, 0.5);
    text-transform: uppercase;
  }

  .maison_commerce_maison_main_product__variant-value {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.5;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  .maison_commerce_maison_main_product__variant-thumbnails {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .maison_commerce_maison_main_product__variant-thumbnail {
    width: 64px;
    height: 64px;
    border: 1.5px solid transparent;
    background: #F8F8F8;
    padding: 0;
    cursor: pointer;
    border-radius: 0;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .maison_commerce_maison_main_product__variant-thumbnail:hover{
    border-color: #2d2d2d;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__variant-thumbnail {
      width: 60px;
      height: 60px;
      border-width: 1.406px;
    }
  }

  .maison_commerce_maison_main_product__variant-thumbnail.active {
    border-color: #2d2d2d;
  }

  .maison_commerce_maison_main_product__variant-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .maison_commerce_maison_main_product__room-info {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: #8b8b8b;
    text-align: right;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__room-info {
      font-size: 10px;
    }
  }

  .maison_commerce_maison_main_product__variant-options {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .maison_commerce_maison_main_product__variant-option {
    outline: 1px solid rgba(0, 0, 0, 0.08);
    border: none;
    background: white;
    padding: 8px 22px;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: #1a1a1a;
    text-transform: uppercase;
    cursor: pointer;
    transition: outline-color 0.3s ease, background-color 0.3s ease;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__variant-option {
      font-size: 10px;
    }
  }

  .maison_commerce_maison_main_product__variant-option:hover {
    outline-color: #1a1a1a;
  }

  .maison_commerce_maison_main_product__variant-option.active {
    outline-color: #1a1a1a;
  }

  /* Smell swatch (image only) */
  .maison_commerce_maison_main_product__variant-option--has-img {
    padding: 0;
    width: 64px;
    height: 64px;
    background: #f8f8f8;
    outline: none;
    border: 1.5px solid transparent;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .maison_commerce_maison_main_product__variant-option--has-img:hover {
    outline: none;
    border-color: #2d2d2d;
  }

  .maison_commerce_maison_main_product__variant-option--has-img.active {
    outline: none;
    border-color: #2d2d2d;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__variant-option--has-img {
      width: 60px;
      height: 60px;
      border-width: 1.406px;
    }
  }

  .maison_commerce_maison_main_product__variant-option-img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .maison_commerce_maison_main_product__variant-option-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .maison_commerce_maison_main_product__variant-picker-hidden {
    display: none;
  }

  /* Fragrance info icon + popup */
  .maison_commerce_maison_main_product__fragrance-info-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin-left: 2px;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(26, 26, 26, 0.45);
    transition: color 0.2s ease;
    line-height: 0;
  }

  .maison_commerce_maison_main_product__fragrance-info-btn:hover {
    color: #1a1a1a;
  }

  .maison_commerce_maison_main_product__fragrance-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .maison_commerce_maison_main_product__fragrance-modal.is-open {
    display: flex;
  }

  .maison_commerce_maison_main_product__fragrance-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.4);
  }

  .maison_commerce_maison_main_product__fragrance-modal-dialog {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 760px;
    max-height: 85vh;
    overflow-y: auto;
    padding: 56px 64px;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__fragrance-modal-dialog {
      padding: 48px 24px;
    }
  }

  .maison_commerce_maison_main_product__fragrance-modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: #1a1a1a;
    cursor: pointer;
  }

  .maison_commerce_maison_main_product__fragrance-modal-content {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .maison_commerce_maison_main_product__fragrance-part {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .maison_commerce_maison_main_product__fragrance-part-title {
    font-family: 'Dangmen', sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.2;
    text-transform: uppercase;
    color: #1a1a1a;
    margin: 0;
  }

  .maison_commerce_maison_main_product__fragrance-part-desc {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(26, 26, 26, 0.75);
    margin: 0;
  }

  .maison_commerce_maison_main_product__fragrance-part-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    line-height: 1.4;
    color: #1a1a1a;
  }

  .maison_commerce_maison_main_product__fragrance-part-list-sep {
    color: rgba(26, 26, 26, 0.4);
  }

  /* Shipping */
  .maison_commerce_maison_main_product__shipping {
    background: rgba(235, 234, 232, 0.4);
    padding: 4px 16px;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(26, 26, 26, 0.75);
    text-align: center;
  }

  .maison_commerce_maison_main_product__shipping a {
    color: #1a1a1a;
    text-decoration: underline;
  }

  /* Form */
  .maison_commerce_maison_main_product__form {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Button */
  .maison_commerce_maison_main_product__button {
    background-color: #090909;
    color: #fdfcfc;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.5;
    text-transform: uppercase;
    border: none;
    padding: 16px 32px;
    height: 56px;
    cursor: pointer;
    transition: opacity 0.3s ease;
    font-family: 'Celex Grotesk', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__button {
      height: 44px;
      padding: 12px 24px;
      gap: 8px;
    }
  }

  .maison-add-to-cart-button-price{
    font-size: 16px;
  }

  @media (max-width: 990px) {
    .maison-add-to-cart-button{
      font-size: 14px!important;
    }

    .maison-add-to-cart-button-price{
      font-size: 14px!important;
    }
  }

  .maison_commerce_maison_main_product__button:hover:not(:disabled) {
    opacity: 0.9;
  }

  .maison_commerce_maison_main_product__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .maison_commerce_maison_main_product__button-separator {
    color: #434343;
    font-size: 16px;
  }

  .maison_commerce_maison_main_product__button-price {
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__button-price {
      font-size: 14px;
    }
  }

  /* Payment Icons */
  .maison_commerce_maison_main_product__payment-icons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Benefits */
  .maison_commerce_maison_main_product__benefits {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    gap: 8px;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__benefits {
      padding: 8px 0px;
      justify-content: center;
    }
  }

  .maison_commerce_maison_main_product__benefit {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(26, 26, 26, 0.75);
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__benefit {
      font-size: 10px;
    }
  }

  .maison_commerce_maison_main_product__benefit-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .maison_commerce_maison_main_product__benefit-icon svg,
  .maison_commerce_maison_main_product__benefit-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .maison_commerce_maison_main_product__benefit-divider {
    display: flex!important;
    width: 0;
    height: 10px;
    border-left: 1px solid rgba(0, 0, 0, 0.08);
  }

  /* Accordions */
  .maison_commerce_maison_main_product__accordions {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .maison_commerce_maison_main_product__accordion {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .maison_commerce_maison_main_product__accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    cursor: pointer;
    list-style: none;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    color: #1a1a1a;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__accordion-header {
      padding: 12px 0;
      font-size: 12px;
    }
  }

  .maison_commerce_maison_main_product__accordion-header::-webkit-details-marker {
    display: none;
  }

  .maison_commerce_maison_main_product__accordion-header svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  details[open] .maison_commerce_maison_main_product__accordion-header svg {
    transform: rotate(45deg);
  }

  .maison_commerce_maison_main_product__accordion-content {
    padding-bottom: 18px;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    color: #1a1a1a;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__accordion-content {
      padding-bottom: 12px;
      font-size: 12px;
    }
  }

  .maison_commerce_maison_main_product__accordion-specs {
    margin-top: 16px;
  }

  .maison_commerce_maison_main_product__specs-table {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    overflow: hidden;
  }

  .maison_commerce_maison_main_product__specs-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
  }

  .maison_commerce_maison_main_product__specs-row + .maison_commerce_maison_main_product__specs-row {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .maison_commerce_maison_main_product__specs-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 8px;
    font-size: 13px;
    line-height: 1.4;
    color: #1a1a1a;
    text-align: center;
  }

  .maison_commerce_maison_main_product__specs-row--head {
    background: rgba(235, 234, 232, 0.4);
  }

  .maison_commerce_maison_main_product__specs-row--head .maison_commerce_maison_main_product__specs-cell {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(26, 26, 26, 0.6);
  }

  .maison_commerce_maison_main_product__specs-row--head svg {
    flex-shrink: 0;
  }

  .maison_commerce_maison_main_product__specs-size {
    font-weight: 600;
  }

  .maison_commerce_maison_main_product__specs-caption {
    margin: 8px 0 0 0;
    font-size: 12px;
    color: rgba(26, 26, 26, 0.5);
    text-align: center;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__specs-cell {
      font-size: 12px;
      padding: 8px 6px;
    }
  }

  .maison_commerce_maison_main_product__accordion-image {
    margin-top: 12px;
  }

  .maison_commerce_maison_main_product__accordion-image-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Promo */
  .maison_commerce_maison_main_product__promo {
    background: #fafafa;
    padding: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: center;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(26, 26, 26, 0.75);
    margin-bottom: 18px;
  }

  .maison_commerce_maison_main_product__promo-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .maison_commerce_maison_main_product__promo-icon svg,
  .maison_commerce_maison_main_product__promo-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Size Chart */
  .maison_commerce_maison_main_product__size-chart {
    width: 100%;
    margin-top: 0;
  }

  .maison_commerce_maison_main_product__size-chart-img {
    width: 100%;
    max-width: 409px;
    margin: 0 auto;
    height: auto;
    display: block;
  }

  @media (max-width: 990px) {
    .maison_commerce_maison_main_product__size-chart {
      width: 100%;
      max-width: 339px;
      margin: 0 auto;
    }
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const productInfo = document.querySelector('#MainProduct-{{ section.id }}');
    if (!productInfo) return;

    const productData = JSON.parse(productInfo.dataset.productJson);
    
    // Get variant metafields mapping
    const variantMetafieldsScript = document.getElementById('variant-metafields-{{ section.id }}');
    const variantMetafields = variantMetafieldsScript ? JSON.parse(variantMetafieldsScript.textContent) : {};

    // Map each variant to its featured media id (for mobile slider sync)
    const variantMediaMap = {
      {%- for variant in product.variants -%}
        "{{ variant.id }}": {{ variant.featured_media.id | default: 'null' }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    };

    // Reference to the mobile gallery Swiper instance
    let mobileSwiper = null;

    // Gallery / Size-binding config (from Liquid)
    const hasSizeOption = {% if has_size_option %}true{% else %}false{% endif %};
    const sizeOptionPosition = {{ size_option_position | default: 0 }};

    // Capture mobile slider slides up-front so we can filter them by Size
    const mobileGalleryEl = productInfo.querySelector('.maison_commerce_maison_main_product__gallery-slider');
    const mobileWrapper = mobileGalleryEl ? mobileGalleryEl.querySelector('.swiper-wrapper') : null;
    const allMobileSlides = mobileWrapper ? Array.from(mobileWrapper.children) : [];

    // Gallery expand/collapse + current Size state
    let galleryExpanded = false;
    let currentGallerySize = null;

    // Does a gallery element (grid item / slide) match the selected Size?
    function mediaMatchesSize(el, size) {
      const raw = (el.dataset.mediaSizes || '').trim();
      if (!raw) return true;        // no Size tag in alt → always visible
      if (!size) return true;       // no Size selected/available → show all
      const list = raw.split(',').map(s => s.trim().toLowerCase()).filter(Boolean);
      return list.includes(String(size).toLowerCase());
    }

    // Resolve the selected Size value from a variant
    function currentSizeFromVariant(variant) {
      if (!hasSizeOption || !variant || !variant.options) return null;
      return variant.options[sizeOptionPosition - 1] || null;
    }

    // Show the Limited Edition badge only on the first visible mobile slide
    function setFirstSlideBadge() {
      if (!mobileWrapper) return;
      Array.from(mobileWrapper.children).forEach((slide, i) => {
        const badge = slide.querySelector('.maison_commerce_maison_main_product__badge');
        if (badge) badge.style.display = i === 0 ? 'block' : 'none';
      });
    }

    // Desktop grid: filter by Size, then collapse matched items beyond the first 4
    function renderDesktopGrid(size) {
      const grid = productInfo.querySelector('[data-gallery-grid]');
      if (!grid) return;

      const items = Array.from(grid.querySelectorAll('[data-gallery-item]'));
      const matched = [];
      items.forEach(item => {
        if (mediaMatchesSize(item, size)) {
          item.classList.remove('is-size-hidden');
          matched.push(item);
        } else {
          item.classList.add('is-size-hidden');
        }
      });

      matched.forEach((item, i) => {
        if (i >= 4 && !galleryExpanded) {
          item.classList.add('is-collapsed-hidden');
        } else {
          item.classList.remove('is-collapsed-hidden');
        }
      });

      // Show the badge only on the first visible (matched) grid item
      items.forEach(item => {
        const badge = item.querySelector('.maison_commerce_maison_main_product__badge');
        if (badge) badge.style.display = 'none';
      });
      if (matched[0]) {
        const firstBadge = matched[0].querySelector('.maison_commerce_maison_main_product__badge');
        if (firstBadge) firstBadge.style.display = 'block';
      }

      const toggle = productInfo.querySelector('[data-gallery-toggle]');
      if (toggle) {
        if (matched.length > 4) {
          toggle.style.display = '';
          toggle.setAttribute('aria-expanded', String(galleryExpanded));
          const label = toggle.querySelector('[data-gallery-toggle-label]');
          if (label) {
            label.textContent = galleryExpanded
              ? (label.dataset.labelLess || 'Show less')
              : `${label.dataset.labelMore || 'View all photos'} (${matched.length})`;
          }
        } else {
          toggle.style.display = 'none';
        }
      }
    }

    // Mobile slider: keep only slides matching the selected Size
    function rebuildMobileSlides(size) {
      if (!mobileWrapper) return;

      const matching = allMobileSlides.filter(s => mediaMatchesSize(s, size));
      const visible = matching.length ? matching : allMobileSlides;

      // Detach all, then re-append the visible ones in their original order
      allMobileSlides.forEach(s => {
        if (s.parentNode === mobileWrapper) mobileWrapper.removeChild(s);
      });
      visible.forEach(s => mobileWrapper.appendChild(s));

      if (mobileSwiper && !mobileSwiper.destroyed) {
        mobileSwiper.update();
        mobileSwiper.slideTo(0, 0);
      }
      setFirstSlideBadge();
    }

    // Apply the Size filter across both desktop grid and mobile slider
    function applyGalleryFilter(size) {
      currentGallerySize = size;
      renderDesktopGrid(size);
      rebuildMobileSlides(size);
    }

    // Move the mobile slider to the slide matching the variant's featured media
    function goToVariantMedia(variant) {
      if (!mobileSwiper || mobileSwiper.destroyed || !variant) return;
      const mediaId = variantMediaMap[variant.id];
      if (!mediaId) return;
      const slides = mobileSwiper.slides;
      for (let i = 0; i < slides.length; i++) {
        if (parseInt(slides[i].dataset.mediaId, 10) === mediaId) {
          mobileSwiper.slideTo(i);
          break;
        }
      }
    }

    // Store settings from Liquid
    const currencyCodeEnabled = {{ settings.currency_code_enabled | default: false }};
    const saleMessage = {{ settings.sale_message | json }};
    const saleBadgeColorScheme = '{{ settings.sale_badge_color_scheme | default: "accent-1" }}';
    const soldOutBadgeColorScheme = '{{ settings.sold_out_badge_color_scheme | default: "accent-1" }}';
    const regularPriceText = '{{ "products.product.price.regular_price" | t }}';
    const salePriceText = '{{ "products.product.price.sale_price" | t }}';
    const onSaleText = '{{ "products.product.on_sale" | t }}';
    const soldOutText = '{{ "products.product.sold_out" | t }}';
    const moneyFormat = '{{ shop.money_format }}';
    console.log('moneyFormat', moneyFormat);
    const currencyCode = '{{ cart.currency.iso_code }}';
    const locale = '{{ request.locale.iso_code }}';

    // Free Refill / Founder Savings config (from Liquid)
    const founderBadgeActive = {% if show_founder_badge %}true{% else %}false{% endif %};
    const founderBadgeTemplate = {{ free_refill_badge | json }};

    // Recompute the Founder Savings percent for the selected variant:
    // percent off the regular price relative to compare_at_price.
    function updateFounderBadge(variant) {
      if (!founderBadgeActive || !variant) return;
      const badgeEl = productInfo.querySelector('[data-founder-badge]');
      if (!badgeEl) return;

      const compare = variant.compare_at_price || 0;
      const price = variant.price || 0;

      let percent = 0;
      if (compare > 0) {
        percent = Math.round(((compare - price) / compare) * 100);
        if (percent < 0) percent = 0;
      }

      badgeEl.textContent = (founderBadgeTemplate || '').replace('[percent]', percent + '%');
    }

    // Helper function to format money (matching Shopify's format)
    function formatMoney(cents, withCurrency = false) {
      if (typeof window.Shopify !== 'undefined' && window.Shopify.formatMoney) {
        // Use Shopify's formatMoney if available
        let formatted = window.Shopify.formatMoney(cents, moneyFormat);
        if (withCurrency) {
          formatted = formatted.replace(',00', '');
        }
        return formatted;
      }
      
      // Fallback to Intl.NumberFormat
      const amount = cents / 100;
      const options = {
        style: 'currency',
        currency: currencyCode,
        minimumFractionDigits: 0,
        maximumFractionDigits: 2
      };
      
      return new Intl.NumberFormat(locale, options).format(amount);
    }

    // Update main price element following price.liquid snippet logic
    function updateMainPrice(variant) {
      const priceContainer = productInfo.querySelector('.maison_commerce_maison_main_product__price');
      if (!priceContainer || !variant) return;

      const price = variant.price || 0;
      const compareAtPrice = variant.compare_at_price || 0;
      const available = variant.available !== false;
      const isOnSale = compareAtPrice > price && compareAtPrice > 0;
      
      let moneyPrice = formatMoney(price, currencyCodeEnabled);
      let moneyCompareAtPrice = formatMoney(compareAtPrice, currencyCodeEnabled);

      // Build price classes for the inner price block
      let priceBlockClasses = 'price price--large';
      if (isOnSale) {
        priceBlockClasses += ' price--on-sale price--show-badge';
      }
      if (!available) {
        priceBlockClasses += ' price--sold-out';
      }

      // Build price HTML following price.liquid structure
      let priceHTML = `<div class="${priceBlockClasses}">`;
      priceHTML += '<div class="price__container">';
      
      if (isOnSale) {
        // Show sale price with compare at price
        priceHTML += '<div class="price__sale">';
        priceHTML += '<span class="lumin-price-container">';
        priceHTML += `<span class="visually-hidden visually-hidden--inline">${regularPriceText}</span>`;
        priceHTML += `<span class="price-item price-item--sale price-item--last price-item--highlight">${moneyPrice}</span>`;
        priceHTML += `<span class="price-item price-item--regular price-item--strikethrough">${moneyCompareAtPrice}</span>`;
        priceHTML += `<span class="visually-hidden visually-hidden--inline">${salePriceText}</span>`;
        priceHTML += '</span>';
        priceHTML += '</div>';
      } else {
        // Show regular price
        priceHTML += '<div class="price__regular">';
        priceHTML += `<span class="visually-hidden visually-hidden--inline">${regularPriceText}</span>`;
        priceHTML += `<span class="price-item price-item--regular">${moneyPrice}</span>`;
        priceHTML += '</div>';
      }
      
      priceHTML += '</div>';
      
      // Add sale badge if on sale
      if (isOnSale) {
        const savings = compareAtPrice - price;
        const savingsFormatted = formatMoney(savings);
        const percentage = Math.round((savings / compareAtPrice) * 100);
        let badgeText = saleMessage || onSaleText;
        
        // Replace placeholders in sale message
        if (saleMessage) {
          badgeText = badgeText.replace('[$]', savingsFormatted).replace('[%]', percentage + '%');
        }
        
        priceHTML += `<span class="lm-badge badge price__badge-sale color-${saleBadgeColorScheme}">`;
        priceHTML += badgeText;
        priceHTML += '</span>';
      }
      
      // Add sold out badge if unavailable
      if (!available) {
        priceHTML += `<span class="badge price__badge-sold-out color-${soldOutBadgeColorScheme}">`;
        priceHTML += soldOutText;
        priceHTML += '</span>';
      }

      priceHTML += '</div>';
      
      // Update HTML (replace innerHTML with new price block, preserve container classes)
      priceContainer.innerHTML = priceHTML;
    }

    // Update button price (simple price without discount)
    function updateButtonPrice(variant) {
      // Try multiple selectors for button price
      const buttonPriceSelectors = [
        '#button-price-{{ section.id }}',
        '.maison-add-to-cart-button-price',
        '.maison_commerce_maison_main_product__button-price',
        '.product-form__submit .maison-add-to-cart-button-price'
      ];
      
      let priceEl = null;
      for (const selector of buttonPriceSelectors) {
        priceEl = productInfo.querySelector(selector) || document.querySelector(selector);
        if (priceEl) break;
      }
      
      if (priceEl && variant && variant.price) {
        priceEl.textContent = formatMoney(variant.price, currencyCodeEnabled);
      }
    }

    // Handle variant thumbnail clicks
    const thumbnails = productInfo.querySelectorAll('.maison_commerce_maison_main_product__variant-thumbnail');
    thumbnails.forEach(thumbnail => {
      thumbnail.addEventListener('click', function() {
        const value = this.dataset.value;
        const optionPosition = parseInt(this.dataset.optionPosition);
        
        // Update active state
        const sameOptionGroup = productInfo.querySelectorAll(`[data-option-position="${optionPosition}"].maison_commerce_maison_main_product__variant-thumbnail`);
        sameOptionGroup.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        
        // Update selected value display
        const selectedValueEl = productInfo.querySelector('#selected-size-{{ section.id }}');
        if (selectedValueEl) {
          selectedValueEl.textContent = value;
        }
        
        // Find and trigger the variant-selects component
        const variantSelects = productInfo.querySelector('variant-selects');
        if (variantSelects) {
          const optionInput = variantSelects.querySelector(`input[name="options[${optionPosition}]"][value="${value}"]`);
          if (optionInput) {
            optionInput.checked = true;
            optionInput.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
      });
    });

    // Handle variant option clicks
    const options = productInfo.querySelectorAll('.maison_commerce_maison_main_product__variant-option');
    options.forEach(option => {
      option.addEventListener('click', function() {
        const value = this.dataset.value;
        const optionPosition = parseInt(this.dataset.optionPosition);
        
        // Update active state
        const sameGroup = productInfo.querySelectorAll(`[data-option-position="${optionPosition}"].maison_commerce_maison_main_product__variant-option`);
        sameGroup.forEach(o => o.classList.remove('active'));
        this.classList.add('active');

        // Update selected smell label display
        const selectedSmellEl = productInfo.querySelector('#selected-smell-{{ section.id }}');
        if (selectedSmellEl) {
          selectedSmellEl.textContent = value;
        }

        // Find and trigger the variant-selects component
        const variantSelects = productInfo.querySelector('variant-selects');
        if (variantSelects) {
          const optionInput = variantSelects.querySelector(`input[name="options[${optionPosition}]"][value="${value}"]`);
          if (optionInput) {
            optionInput.checked = true;
            optionInput.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
      });
    });
    
    // Function to get selected variant from selected options
    function getSelectedVariantFromOptions() {
      const variantSelects = productInfo.querySelector('variant-selects');
      if (!variantSelects) return null;

      // Get all selected option values in order
      const selectedOptions = [];
      const optionInputs = variantSelects.querySelectorAll('input[type="radio"][name^="options["]:checked');
      
      // Sort by option position to ensure correct order
      const sortedInputs = Array.from(optionInputs).sort((a, b) => {
        const aPos = parseInt(a.name.match(/options\[(\d+)\]/)[1]);
        const bPos = parseInt(b.name.match(/options\[(\d+)\]/)[1]);
        return aPos - bPos;
      });

      sortedInputs.forEach(input => {
        selectedOptions.push(input.value);
      });

      // Find matching variant from product data
      if (productData && productData.variants) {
        const matchingVariant = productData.variants.find(variant => {
          if (!variant.options || variant.options.length !== selectedOptions.length) {
            return false;
          }
          return variant.options.every((option, index) => option === selectedOptions[index]);
        });

        return matchingVariant || null;
      }

      return null;
    }

    // Track last updated variant to prevent duplicate updates
    let lastUpdatedVariantId = null;
    let isUpdating = false;

    // Update room info and UI when variant changes
    function updateVariantInfo() {
      if (isUpdating) return;
      
      const selectedVariant = getSelectedVariantFromOptions();
      
      if (!selectedVariant) {
        // Fallback: try to get from script tag
        const variantSelects = productInfo.querySelector('variant-selects');
        if (variantSelects) {
          const selectedVariantJson = variantSelects.querySelector('script[data-selected-variant]');
          if (selectedVariantJson) {
            try {
              const variant = JSON.parse(selectedVariantJson.textContent);
              updateVariantUI(variant);
              return;
            } catch (err) {
              console.error('Error parsing variant data:', err);
            }
          }
        }
        return;
      }

      // Prevent duplicate updates
      if (lastUpdatedVariantId === selectedVariant.id) {
        return;
      }

      updateVariantUI(selectedVariant);
    }

    function updateVariantUI(selectedVariant) {
      if (!selectedVariant || !selectedVariant.id) return;
      
      // Prevent duplicate updates
      if (lastUpdatedVariantId === selectedVariant.id && isUpdating) {
        return;
      }

      isUpdating = true;
      lastUpdatedVariantId = selectedVariant.id;

      // Update room info from metafields mapping
      const roomInfoEl = productInfo.querySelector('#room-info-{{ section.id }}');
      if (roomInfoEl) {
        const variantMetafield = variantMetafields[selectedVariant.id];
        if (variantMetafield && variantMetafield.size_additional_description) {
          roomInfoEl.textContent = variantMetafield.size_additional_description;
        } else {
          roomInfoEl.textContent = '';
        }
      }
      
      // Update form variant ID (only if different)
      const form = productInfo.querySelector('#product-form-{{ section.id }}');
      if (form) {
        const variantInput = form.querySelector('input[name="id"]');
        if (variantInput && variantInput.value !== selectedVariant.id.toString()) {
          variantInput.value = selectedVariant.id;
          // Don't dispatch change event here to avoid triggering duplicate updates
        }
      }
      
      // Update main price element (following price.liquid snippet logic)
      updateMainPrice(selectedVariant);
      
      // Update button price (simple price without discount)
      updateButtonPrice(selectedVariant);

      // Recompute the Founder Savings badge for this variant
      updateFounderBadge(selectedVariant);

      // Filter gallery media by the selected Size (matched via image alt tags)
      applyGalleryFilter(currentSizeFromVariant(selectedVariant));

      // Sync mobile gallery slider to the variant's image
      goToVariantMedia(selectedVariant);

      // Update URL
      const productUrl = productInfo.dataset.url || '{{ product.url }}';
      const updateUrl = productInfo.dataset.updateUrl !== 'false';
      
      if (updateUrl && selectedVariant.id) {
        const newUrl = `${productUrl}?variant=${selectedVariant.id}`;
        
        // Use product-info component's updateURL method if available
        if (productInfo.updateURL && typeof productInfo.updateURL === 'function') {
          productInfo.updateURL(productUrl, selectedVariant.id);
        } else {
          // Fallback: manually update URL
          window.history.replaceState(
            {},
            '',
            newUrl
          );
        }
      }

      // Reset updating flag after a short delay
      setTimeout(() => {
        isUpdating = false;
      }, 200);
    }

    // Listen for option changes (with debouncing)
    let updateTimeout;
    productInfo.addEventListener('change', function(e) {
      if (e.target.name && e.target.name.startsWith('options[')) {
        clearTimeout(updateTimeout);
        // Wait a bit for variant-selects to update
        updateTimeout = setTimeout(() => {
          updateVariantInfo();
        }, 150);
      }
    });

    // Also listen for variant:change event (but only if variant-selects hasn't already updated)
    document.addEventListener('variant:change', function(e) {
      if (e.detail && e.detail.variant) {
        // Only update if it's a different variant
        if (lastUpdatedVariantId !== e.detail.variant.id) {
          updateVariantUI(e.detail.variant);
        }
      } else {
        updateVariantInfo();
      }
    });

    // Initialize Swiper for mobile gallery
    function initMobileGallerySwiper() {
      if (window.innerWidth <= 990) {
        const swiperContainer = productInfo.querySelector('.maison_commerce_maison_main_product__gallery-slider');
        
        if (swiperContainer && !swiperContainer.swiper) {
          mobileSwiper = new Swiper('.maison_commerce_maison_main_product__gallery-slider', {
            slidesPerView: 1,
            spaceBetween: 8,
            loop: false,
            pagination: {
              el: '.maison_commerce_maison_main_product__gallery-pagination',
              clickable: true,
              renderBullet: function (index, className) {
                return '<span class="' + className + '"></span>';
              },
            },
            on: {
              init: function(swiperInstance) {
                // Ensure first slide badge is visible
                swiperInstance.slides.forEach((slide, index) => {
                  const badge = slide.querySelector('.maison_commerce_maison_main_product__badge');
                  if (badge) {
                    badge.style.display = index === 0 ? 'block' : 'none';
                  }
                });
              },
              slideChange: function(swiperInstance) {
                // Show badge only on first slide
                swiperInstance.slides.forEach((slide, index) => {
                  const badge = slide.querySelector('.maison_commerce_maison_main_product__badge');
                  if (badge) {
                    badge.style.display = index === swiperInstance.activeIndex && swiperInstance.activeIndex === 0 ? 'block' : 'none';
                  }
                });
              },
            },
          });
        }
      } else {
        // Destroy Swiper if window is resized to desktop
        const swiperContainer = productInfo.querySelector('.maison_commerce_maison_main_product__gallery-slider');
        if (swiperContainer && swiperContainer.swiper) {
          swiperContainer.swiper.destroy(true, true);
          mobileSwiper = null;
        }
      }
    }

    // Initialize on load
    initMobileGallerySwiper();

    // Select the middle Size thumbnail by default (unless a specific variant is in the URL)
    (function selectDefaultMiddleSize() {
      {%- unless section.settings.auto_select_middle_size -%}
        return; // disabled via section settings
      {%- endunless -%}

      const params = new URLSearchParams(window.location.search);
      if (params.has('variant')) return; // respect an explicit variant link

      const sizeThumbnails = productInfo.querySelectorAll('.maison_commerce_maison_main_product__variant-thumbnail');
      if (sizeThumbnails.length < 2) return;

      // Refill products default to the large (last) size; others to the middle
      const isRefill = {% if product.title contains 'Refill' or product.title contains 'refill' %}true{% else %}false{% endif %};
      const targetIndex = isRefill
        ? sizeThumbnails.length - 1
        : Math.floor(sizeThumbnails.length / 2);
      const targetThumb = sizeThumbnails[targetIndex];
      if (targetThumb && !targetThumb.classList.contains('active')) {
        targetThumb.click();
      }
    })();

    // Gallery grid "View all photos" toggle — reveals the remaining matched items
    const galleryToggle = productInfo.querySelector('[data-gallery-toggle]');
    if (galleryToggle) {
      galleryToggle.addEventListener('click', function() {
        galleryExpanded = !galleryExpanded;
        renderDesktopGrid(currentGallerySize);
      });
    }

    // Initial gallery filter (Size may be refined by auto-select / variant change)
    applyGalleryFilter(currentSizeFromVariant(getSelectedVariantFromOptions()));

    // Fragrance info popup
    (function initFragranceInfo() {
      const modal = productInfo.querySelector('[data-fragrance-modal]');
      if (!modal) return;

      const openTriggers = productInfo.querySelectorAll('[data-fragrance-info-open]');
      const closeTriggers = modal.querySelectorAll('[data-fragrance-info-close]');

      function openModal() {
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      openTriggers.forEach(t => t.addEventListener('click', openModal));
      closeTriggers.forEach(t => t.addEventListener('click', closeModal));

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) {
          closeModal();
        }
      });
    })();

    // Reinitialize on resize
    let resizeTimeout;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(function() {
        initMobileGallerySwiper();
      }, 250);
    });
  });
</script>

