{%- comment -%}
  Outputs a comma-separated, downcased list of Size option values that match
  this media's alt text. Sizes in the alt should be separated by a comma or
  semicolon (e.g. "Small" or "Small, Large"). Each alt token is matched by
  substring (case-insensitive) against the product's Size option values, so a
  short keyword like "Small" matches a full value like "Small | 4.7 OZ".

  Accepts:
  - media: {Object} product media object
  - size_values: {String} comma-joined list of the product's Size option values

  Usage:
  {%- capture media_sizes -%}
    {%- render 'media-size-match', media: media, size_values: size_values -%}
  {%- endcapture -%}
{%- endcomment -%}
{%- assign _sizes = size_values | split: ',' -%}
{%- assign _alt = media.alt | default: '' | downcase | replace: ';', ',' -%}
{%- assign _alt_tokens = _alt | split: ',' -%}
{%- assign _out = '' -%}
{%- for sv in _sizes -%}
  {%- assign _sv = sv | strip | downcase -%}
  {%- if _sv == '' -%}{%- continue -%}{%- endif -%}
  {%- for tok in _alt_tokens -%}
    {%- assign _tok = tok | strip -%}
    {%- if _tok == '' -%}{%- continue -%}{%- endif -%}
    {%- if _sv contains _tok -%}
      {%- assign _out = _out | append: _sv | append: ',' -%}
    {%- endif -%}
  {%- endfor -%}
{%- endfor -%}
{{- _out | split: ',' | uniq | join: ',' -}}
